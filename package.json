{
  "name": "brameda-astro",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "sync": "astro sync",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "compile": "tsc",
    "lint": "npm run lint:code && npm run lint:format && npm run compile -- --noEmit",
    "lint:fix": "npm run lint:code:fix && npm run lint:format:fix",
    "lint:code": "npx eslint src/** --report-unused-disable-directives",
    "lint:code:fix": "npm run lint:code -- --fix",
    "lint:format": "npx prettier --check \"src/**\"",
    "lint:format:fix": "npx prettier --write \"src/**\""
  },
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/react": "^4.4.2",
    "@astrojs/sitemap": "^3.7.0",
    "@contentful/rich-text-html-renderer": "^17.1.6",
    "@contentful/rich-text-plain-text-renderer": "^17.1.6",
    "@hookform/error-message": "^2.0.1",
    "@hookform/resolvers": "^5.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^5.18.0",
    "clsx": "^2.1.1",
    "contentful": "^11.10.5",
    "embla-carousel-react": "^8.6.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^2.13.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "astro-eslint-parser": "^1.3.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.0.2",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-perfectionist": "^5.6.0",
    "prettier-plugin-astro": "^0.14.1",
    "typescript-eslint": "^8.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
