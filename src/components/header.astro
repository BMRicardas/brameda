---
import type { Link } from "@/types";
import Branding from "./ui/branding.astro";
import Container from "./ui/container.astro";
import Navigation from "./ui/navigation.astro";

const headerLinks = [
  {
    href: "#products",
    text: "Produktai",
  },
  {
    href: "#about",
    text: "Apie mus",
  },
  {
    href: "#contacts",
    text: "Kontaktai",
  },
] satisfies Link[];
---

<header id="header" class="header">
  <Container class="header-container">
    <Branding />
    <Navigation links={headerLinks} />
  </Container>
</header>

<style>
  .header {
    position: sticky;
    background-color: var(--color-white);
    inset-block-start: 0;
    inset-inline: 0;
    anchor-name: --header;
    z-index: 1;
    padding-block: 0.5rem;

    animation-name: scrolledHeader;

    transition-duration: var(--transition-duration);
    animation-fill-mode: var(--animation-fill-mode);
    animation-timeline: var(--animation-timeline);
    animation-range-start: var(--animation-range-start);
    animation-range-end: var(--animation-range-end);
  }

  .header-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  @keyframes scrolledHeader {
    from {
      box-shadow: none;
    }
    to {
      box-shadow: 0 0 5px 3px rgba(0, 0, 0, 0.15);
    }
  }
</style>

<script>
  function numbersOnly(value: string | number | undefined) {
    if (typeof value === "undefined") return "";

    if (typeof value === "number") {
      const str = String(value);
      return str.replaceAll(/\D/g, "");
    }

    return value.replaceAll(/\D/g, "");
  }

  function setHeaderHeight() {
    const headerHeight = numbersOnly(
      document.getElementById("header")?.offsetHeight,
    );
    const headerHeightProperty = numbersOnly(
      document.documentElement.style.getPropertyValue("--header-height"),
    );

    const isHeightEqual = headerHeight === headerHeightProperty;

    if (isHeightEqual) return;

    document.documentElement.style.setProperty("--header-height", headerHeight);
  }

  window.addEventListener("DOMContentLoaded", setHeaderHeight);
  window.addEventListener("scroll", setHeaderHeight);
</script>
