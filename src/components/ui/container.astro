---
import type { HTMLTag, Polymorphic } from "astro/types";

type Props<Tag extends HTMLTag> = Polymorphic<{ as: Tag; class?: string }>;

const { as: Tag = "div", class: className, ...rest } = Astro.props;
---

<Tag class:list={["container", className]} {...rest}>
  <slot />
</Tag>

<style>
  .container {
    width: var(--max-width);
    max-width: 95%;
    margin-inline: auto;
  }
</style>
