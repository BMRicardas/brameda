---
type Props = {
  title?: string;
  subtitle?: string;
};

const {
  title = "Brameda",
  subtitle = "Pažangūs ergonominiai sprendimai jūsų verslui",
} = Astro.props;
---

<a class="branding" href="/">
  <h1 class="title">
    {title}
  </h1>
  <span class="subtitle">{subtitle}</span>
</a>

<style>
  .branding {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    text-decoration: none;
    color: #000;
  }

  .title,
  .subtitle {
    display: block;
    transform-origin: left center;
    transition-duration: var(--transition-duration);
    animation-fill-mode: var(--animation-fill-mode);
    animation-timeline: var(--animation-timeline);
    animation-range-start: var(--animation-range-start);
    animation-range-end: var(--animation-range-end);
  }

  .title {
    margin: 0;
    font-weight: 700;
    animation-name: scrolledTitle;
  }

  .subtitle {
    align-self: stretch;
    text-align: center;
    font-weight: 500;
    color: var(--color-grey-dark2);
    animation-name: scrolledSubtitle;
  }

  @keyframes scrolledTitle {
    from {
      font-size: 6rem;
      letter-spacing: 2px;
    }
    to {
      font-size: calc((6 * 0.65) * 1rem);
      letter-spacing: 0;
    }
  }

  @keyframes scrolledSubtitle {
    from {
      opacity: 1;
      translate: 0 0;
      font-size: 1.2rem;
      margin-block-start: -1.5rem;
    }
    to {
      opacity: 0;
      translate: 0 -100%;
      font-size: 0;
      margin-block-start: 0;
    }
  }
</style>
