---
import { COMPANY } from "@/constants";

const { ADDRESS, EMAIL, NAME, PHONE } = COMPANY;
---

<div class="contact-details">
  <h3 class="title">{NAME}</h3>
  <address>
    <ul class="contacts-list">
      <li class="contacts-list-item">
        <p>
          {ADDRESS.STREET},<br />{ADDRESS.POST_CODE}
          {ADDRESS.CITY},<br />{ADDRESS.COUNTRY}
        </p>
      </li>
      <li class="contacts-list-item">
        <p>
          <a href=`tel:${PHONE.replaceAll(' ', '')}`>{PHONE}</a>
        </p>
      </li>
      <li class="contacts-list-item">
        <p>
          <a href=`mailto:${EMAIL}`>{EMAIL}</a>
        </p>
      </li>
    </ul>
  </address>
</div>

<style>
  .contact-details {
    grid-area: details;
    text-align: start;
  }

  .title {
    font-size: 2.5rem;
    font-weight: 500;
    margin-block-end: 1.5rem;
  }

  .contacts-list {
    padding: 0;
  }

  .contacts-list-item:not(:last-child) {
    padding-block-end: 1.5rem;
  }

  .contacts-list-item a:any-link {
    color: var(--color-grey-light);
    text-decoration: none;
  }

  .contacts-list-item a:hover,
  .contacts-list-item a:active {
    text-decoration: underline;
  }

  .contacts-list-item p {
    color: var(--color-grey-light);
  }

  @media only screen and (max-width: 50em) {
    .contact-details {
      text-align: center;
    }
  }
</style>
