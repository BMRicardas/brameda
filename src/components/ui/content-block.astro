---
import type { HTMLTag, Polymorphic } from "astro/types";
import BlockTitle from "./block-title.astro";
import Container from "./container.astro";
import type { Theme } from "@/types";

type Props<Tag extends Extract<HTMLTag, "article" | "section">> = Polymorphic<{
  as: Tag;
  id?: string;
  appearanceMode?: Theme;
  title?: string;
  class?: string;
}>;

const {
  as: Tag = "section",
  id,
  appearanceMode = "light",
  title,
  class: className,
} = Astro.props;
---

<Tag
  id={id}
  class:list={[
    "content-block",
    {
      dark: appearanceMode === "dark",
    },
    className,
  ]}
>
  <Container>
    {title && <BlockTitle {appearanceMode} {title} />}
    <slot />
  </Container>
</Tag>

<style>
  .content-block {
    padding-block: var(--default-spacing);
  }

  .content-block.dark {
    background-color: var(--color-grey-dark2);
    color: var(--color-grey-light);
  }
</style>
