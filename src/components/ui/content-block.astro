---
import BlockTitle from "./block-title.astro";
import Container from "./container.astro";
import type { Tag, Theme } from "@/types";

type Props = {
  id?: string;
  appearanceMode?: Theme;
  title?: string;
  tag?: Tag;
};

const { id, appearanceMode = "light", title, tag = "section" } = Astro.props;

const Element = tag;
---

<Element
  class:list={[
    "content-block",
    {
      dark: appearanceMode !== "light",
    },
  ]}
  id={id}
>
  <Container>
    {title && <BlockTitle {appearanceMode} {title} />}
    <slot />
  </Container>
</Element>

<style>
  .content-block {
    padding-block: var(--default-spacing);
  }

  .content-block.dark {
    background-color: var(--color-grey-dark2);
    color: var(--color-grey-light);
  }
</style>
