---
import { getCollection } from "astro:content";

import type { Product } from "@/schemas/contentful-transformed.types";

import About from "@/components/about.astro";
import Contacts from "@/components/contacts.astro";
import ProductPage from "@/components/product/product-page.astro";
import Layout from "@/layouts/Layout.astro";
import { renderRichTextToPlainText } from "@/lib/rich-text";
import { getMainPhotoUrl } from "@/utils";
import { getProductStructuredData } from "@/utils/seo-schema-builder";

type Props = { product: Product };

export async function getStaticPaths() {
  const products = await getCollection("products");

  return products.map(({ data: product }) => ({
    params: {
      slug: product.slug,
    },
    props: {
      product: product,
    },
  }));
}
const { product } = Astro.props;

const description = renderRichTextToPlainText(product.description);
const mainPhotoUrl = getMainPhotoUrl(product.mainPhoto.url);
const productStructuredData = getProductStructuredData(product, Astro.url.href);
---

<Layout
  description={description}
  image={mainPhotoUrl}
  structuredData={productStructuredData}
  title={product.title}
>
  <ProductPage product={product} />
  <About />
  <Contacts />
</Layout>
