---
import About from "@/components/about.astro";
import Contacts from "@/components/contacts.astro";
import ProductList from "@/components/product/product-list.astro";
import { COMPANY } from "@/constants";
import Layout from "@/layouts/Layout.astro";
import { getItemListStructuredData } from "@/utils/seo-schema-builder";
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import { ORGANIZATION_STRUCTURED_DATA } from "../utils/seo-schema-builder";

const products = await getCollection("products");

function sortByOrder(
  a: CollectionEntry<"products">["data"],
  b: CollectionEntry<"products">["data"],
) {
  return a.order - b.order;
}

const sortedProducts = products.map((p) => p.data).sort(sortByOrder);

const structuredItemListData = getItemListStructuredData(sortedProducts);
---

<Layout
  title={COMPANY.NAME}
  description="UAB Brameda - Jūsų patikimas partneris. Mūsų tikslas - teikti aukščiausios kokybės produktus ir paslaugas, atitinkančias Jūsų poreikius."
  structuredData={[ORGANIZATION_STRUCTURED_DATA, structuredItemListData]}
>
  <ProductList products={sortedProducts} />
  <About />
  <Contacts />
</Layout>
